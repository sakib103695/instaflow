# ===== Voice agent (Vapi) =====
# Public key from https://vapi.ai/account → API Keys. Browser-safe.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key

# ===== Scraping & AI structuring (Google Gemini, server-side only) =====
# Used by /api/clients/[slug]/scrape to convert raw scraped text into a
# structured context. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# ===== MongoDB Atlas =====
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB_NAME=instaflow_db

# ===== Admin gate =====
# Protects /admin and /api/clients via Basic Auth + cookie. Leave unset in
# local dev to disable the gate; REQUIRED in production.
ADMIN_PASSWORD=

# ===== ElevenLabs =====
# Server-side only. Powers the /admin/voices library page (lists all voices,
# previews, lets you toggle which appear in the public picker). Get a key at
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ===== OpenRouter (optional, overrides GEMINI_API_KEY for structuring) =====
# Routes the onboarding "analyze site → structured JSON" call through a
# cheaper model. Get a key at https://openrouter.ai/keys
# The actual model is picked at runtime via /admin/settings (stored in
# Mongo), so switching models needs no redeploy.
OPENROUTER_API_KEY=
